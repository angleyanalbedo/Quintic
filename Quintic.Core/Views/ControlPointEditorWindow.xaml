<Window x:Class="Quintic.Wpf.Views.ControlPointEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Control Points" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="PointsGrid" AutoGenerateColumns="False" CanUserAddRows="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Master Offset" Binding="{Binding Theta}"/>
                <DataGridTextColumn Header="Slave Offset" Binding="{Binding S}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Click="Save_Click" Width="80" Margin="5"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="80" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>

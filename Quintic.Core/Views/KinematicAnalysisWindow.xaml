<Window x:Class="Quintic.Wpf.Views.KinematicAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Kinematic Analysis" SizeToContent="Height" Width="900"
        WindowStyle="ToolWindow" Topmost="True" ResizeMode="CanResize"
        Background="{StaticResource Brush.Control.Background}"
        Foreground="{StaticResource Brush.Text.Primary}">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Control.Border}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Brush.Control.Background}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Control.Border}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <GroupBox Header="Physical Parameters">
                <StackPanel Margin="5">
                    <TextBlock Text="Load Inertia (kg·m²):" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding Config.LoadInertia, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <TextBlock Text="Motor Inertia (kg·m²):" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding Config.MotorInertia, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <TextBlock Text="Friction Torque (Nm):" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding Config.FrictionTorque, UpdateSourceTrigger=PropertyChanged}"/>

                    <Separator Margin="0,5"/>

                    <TextBlock Text="Rated Torque (Nm):" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding RatedTorque, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Max Torque (Nm):" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding MaxTorque, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Analysis Results" Margin="0,10,0,0">
                <StackPanel Margin="5">
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RMS Acceleration:"/>
                        <TextBlock Grid.Column="1" Text="{Binding RmsAcceleration, StringFormat=N2}" FontWeight="Bold"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Peak Jerk:"/>
                        <TextBlock Grid.Column="1" Text="{Binding PeakJerk, StringFormat=N2}" FontWeight="Bold"/>
                    </Grid>

                    <Separator Margin="0,5"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Peak Torque (Nm):"/>
                        <TextBlock Grid.Column="1" Text="{Binding PeakTorque, StringFormat=N2}" FontWeight="Bold" Foreground="Red"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RMS Torque (Nm):"/>
                        <TextBlock Grid.Column="1" Text="{Binding RmsTorque, StringFormat=N2}" FontWeight="Bold"/>
                    </Grid>
                    
                     <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Peak Power (W):"/>
                        <TextBlock Grid.Column="1" Text="{Binding PeakPower, StringFormat=N2}" FontWeight="Bold"/>
                    </Grid>

                    <Separator Margin="0,10"/>
                    <TextBlock Text="Motor Health" FontWeight="Bold" Margin="0,0,0,5"/>

                    <!-- RMS Load Bar -->
                    <Grid Margin="0,2">
                        <TextBlock Text="RMS Load:" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding RmsLoadPercentage, StringFormat={}{0:N0}%}" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar Value="{Binding RmsLoadPercentage}" Height="10" Maximum="120" Foreground="{Binding RmsStatusColor}"/>

                    <!-- Peak Load Bar -->
                    <Grid Margin="0,5,0,2">
                        <TextBlock Text="Peak Load:" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding PeakLoadPercentage, StringFormat={}{0:N0}%}" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar Value="{Binding PeakLoadPercentage}" Height="10" Maximum="120" Foreground="{Binding PeakStatusColor}"/>

                    <!-- Diagnostics Log -->
                    <Border Background="#222" CornerRadius="3" Margin="0,10,0,0" Padding="5">
                        <TextBlock Text="{Binding DiagnosticsLog}" Foreground="White" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
            </GroupBox>
            
            <TextBlock Text="* Updates in real-time as you drag points." 
                       FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>

        <GroupBox Grid.Column="1" Header="T-N Characteristic" Margin="10,0,0,0">
            <oxy:PlotView Model="{Binding TorqueSpeedModel}" Height="400"/>
        </GroupBox>
    </Grid>
</Window>

<Window x:Class="Quintic.Wpf.Views.KinematicAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Kinematic Analysis" SizeToContent="Height" Width="950"
        WindowStyle="ToolWindow" Topmost="True" ResizeMode="CanResize"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.Text.Primary}">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="Border" x:Key="PanelBorder">
            <Setter Property="Background" Value="{StaticResource Brush.Control.Background}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <ControlTemplate x:Key="DarkTrackerTemplate">
            <oxy:TrackerControl Position="{Binding Position}" LineExtents="{Binding PlotModel.PlotArea}">
                <oxy:TrackerControl.Background>
                    <SolidColorBrush Color="#F01A1A1A"/>
                </oxy:TrackerControl.Background>
                <oxy:TrackerControl.BorderBrush>
                    <SolidColorBrush Color="#3498DB"/>
                </oxy:TrackerControl.BorderBrush>
                <oxy:TrackerControl.Content>
                    <TextBlock Text="{Binding}" Margin="8" Foreground="#DDDDDD" FontSize="12"/>
                </oxy:TrackerControl.Content>
            </oxy:TrackerControl>
        </ControlTemplate>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <!-- Physical Parameters -->
            <Border Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="PHYSICAL PARAMETERS" Style="{StaticResource HeaderStyle}"/>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Load Inertia (kg·m²):" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Config.LoadInertia, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Motor Inertia (kg·m²):" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Config.MotorInertia, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Friction Torque (Nm):" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Config.FrictionTorque, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Separator Background="#333" Margin="0,0,0,15" Height="1"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Rated Torque (S1):" VerticalAlignment="Center" Foreground="{StaticResource Brush.Success}"/>
                        <TextBox Grid.Column="1" Text="{Binding RatedTorque, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max Torque (S3):" VerticalAlignment="Center" Foreground="{StaticResource Brush.Warning}"/>
                        <TextBox Grid.Column="1" Text="{Binding MaxTorque, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Analysis Results -->
            <Border Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="ANALYSIS RESULTS" Style="{StaticResource HeaderStyle}"/>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RMS Acceleration:" Foreground="{StaticResource Brush.Text.Secondary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding RmsAcceleration, StringFormat=N2}" FontWeight="Bold" Foreground="{StaticResource Brush.Text.Primary}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Peak Jerk:" Foreground="{StaticResource Brush.Text.Secondary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding PeakJerk, StringFormat=N2}" FontWeight="Bold" Foreground="{StaticResource Brush.Text.Primary}"/>
                    </Grid>

                    <Separator Background="#333" Margin="0,0,0,15" Height="1"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RMS Torque (Nm):" Foreground="{StaticResource Brush.Text.Secondary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding RmsTorque, StringFormat=N2}" FontWeight="Bold" Foreground="{StaticResource Brush.Success}"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Peak Torque (Nm):" Foreground="{StaticResource Brush.Text.Secondary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding PeakTorque, StringFormat=N2}" FontWeight="Bold" Foreground="{StaticResource Brush.Warning}"/>
                    </Grid>
                    
                     <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Peak Power (W):" Foreground="{StaticResource Brush.Text.Secondary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding PeakPower, StringFormat=N2}" FontWeight="Bold" Foreground="{StaticResource Brush.Text.Primary}"/>
                    </Grid>

                    <Separator Background="#333" Margin="0,0,0,15" Height="1"/>
                    <TextBlock Text="MOTOR HEALTH" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Secondary}" Margin="0,0,0,10"/>

                    <!-- RMS Load Bar -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="RMS Load:" FontSize="11" Foreground="{StaticResource Brush.Text.Secondary}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding RmsLoadPercentage, StringFormat={}{0:N0}%}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar Value="{Binding RmsLoadPercentage}" Height="6" Maximum="120" Foreground="{Binding RmsStatusColor}" Background="#222" BorderThickness="0" Margin="0,0,0,15"/>

                    <!-- Peak Load Bar -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Peak Load:" FontSize="11" Foreground="{StaticResource Brush.Text.Secondary}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding PeakLoadPercentage, StringFormat={}{0:N0}%}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar Value="{Binding PeakLoadPercentage}" Height="6" Maximum="120" Foreground="{Binding PeakStatusColor}" Background="#222" BorderThickness="0" Margin="0,0,0,15"/>

                    <!-- Diagnostics Log -->
                    <Border Background="#111111" CornerRadius="4" Padding="10">
                        <TextBlock Text="{Binding DiagnosticsLog}" Foreground="{StaticResource Brush.Text.Primary}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Border>
            
            <TextBlock Text="* Calculations update in real-time." 
                       FontStyle="Italic" FontSize="11" Foreground="{StaticResource Brush.Text.Secondary}" TextWrapping="Wrap" Margin="5,0,0,0"/>
        </StackPanel>

        <!-- T-N Chart -->
        <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="15,0,0,0" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="TORQUE-SPEED CHARACTERISTIC" Style="{StaticResource HeaderStyle}"/>
                <oxy:PlotView Grid.Row="1" Model="{Binding TorqueSpeedModel}" Background="Transparent" DefaultTrackerTemplate="{DynamicResource DarkTrackerTemplate}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

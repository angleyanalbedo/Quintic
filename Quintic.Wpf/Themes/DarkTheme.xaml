<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="Color.Background">#1A1A1A</Color>
    <Color x:Key="Color.Accent">#3498DB</Color>
    <Color x:Key="Color.Success">#2ECC71</Color>
    <Color x:Key="Color.Warning">#E67E22</Color>
    <Color x:Key="Color.PlotBackground">#111111</Color>
    <Color x:Key="Color.PlotLine">#CCCCCC</Color>
    <Color x:Key="Color.PlotLineHighlight">#3498DB</Color>
    <Color x:Key="Color.Text.Primary">#FFFFFF</Color>
    <Color x:Key="Color.Text.Secondary">#BBBBBB</Color>
    <Color x:Key="Color.Control.Background">#2D2D30</Color>
    <Color x:Key="Color.Control.Border">#3E3E42</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.PlotBackground" Color="{StaticResource Color.PlotBackground}"/>
    <SolidColorBrush x:Key="Brush.PlotLine" Color="{StaticResource Color.PlotLine}"/>
    <SolidColorBrush x:Key="Brush.PlotLineHighlight" Color="{StaticResource Color.PlotLineHighlight}"/>
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Control.Background" Color="{StaticResource Color.Control.Background}"/>
    <SolidColorBrush x:Key="Brush.Control.Border" Color="{StaticResource Color.Control.Border}"/>

    <!-- Base Styles for Common Controls -->
    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="{StaticResource Brush.Control.Border}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource Brush.Control.Background}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="RowBackground" Value="{StaticResource Brush.Control.Background}"/>
        <Setter Property="AlternatingRowBackground" Value="#333337"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Control.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>
